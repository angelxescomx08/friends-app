# Copy this file to .env and fill in your values

# Google OAuth Client ID (from Google Cloud Console)
# Under APIs & Services > Credentials > OAuth 2.0 Client IDs
# App type: Desktop app
# Add redirect URI: friendsapp://auth
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# AWS Cognito Identity Pool ID
# Create an Identity Pool in AWS Cognito with Google as identity provider
# Set Google Client ID in the identity pool settings
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AWS region for Cognito + DynamoDB
VITE_AWS_REGION=us-east-1

# DynamoDB table name
# Create with: PK (String), SK (String), GSI1 (GSI1PK String, GSI1SK String)
VITE_DYNAMO_TABLE=friends-app
